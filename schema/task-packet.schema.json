{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ai_supervisor task packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "title",
    "role",
    "target_repo_name",
    "base_ref",
    "goal",
    "allowed_write_paths",
    "constraints",
    "done_criteria"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": [
        "implementer",
        "reviewer",
        "analyst",
        "test-author",
        "documenter",
        "refactorer"
      ]
    },
    "target_repo_name": {
      "type": "string",
      "minLength": 1
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "worker_branch": {
      "type": "string"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "allowed_write_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "read_only_context_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "done_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_notes": {
      "type": "string"
    },
    "rejection_notes": {
      "type": "string"
    },
    "prompt_appendix": {
      "type": "string"
    }
  }
}
