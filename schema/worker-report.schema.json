{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ai_supervisor worker report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "status",
    "summary",
    "files_touched_claimed",
    "assumptions",
    "validation_ran",
    "unresolved_risks",
    "next_step_recommendation"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "partial",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files_touched_claimed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_ran": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "not-run"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "unresolved_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_step_recommendation": {
      "type": "string",
      "minLength": 1
    }
  }
}
